#!/bin/bash
#
# analyze-patterns - Analyze codebase for recurring patterns and refactoring opportunities
#
# Usage: analyze-patterns [--pattern=<pattern>] [--language=<lang>] [--depth=<level>] [--output=<format>]
#
# Examples:
#   analyze-patterns --pattern=error-handling --language=rust
#   analyze-patterns --pattern=factory --depth=deep --output=json
#   analyze-patterns --pattern=async-patterns --output=markdown

set -e

# Default values
PATTERN=""
LANGUAGE=""
DEPTH="medium"
OUTPUT="text"
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Colors for terminal output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Predefined patterns for Rust
declare -A RUST_PATTERNS=(
    ["error-handling"]="(Result<|Error|thiserror|anyhow|\.expect\(|\.unwrap\()"
    ["async-patterns"]="(async |await|tokio::|futures::|spawn)"
    ["singleton"]="(lazy_static!|once_cell|Arc<Mutex|Arc<RwLock)"
    ["factory"]="(fn new\(|impl.*Factory|Factory)"
    ["builder"]="(Builder|fn builder\(|\.build\(\))"
    ["trait-patterns"]="(trait |impl |dyn |Box<dyn)"
    ["mutex-patterns"]="(Mutex|RwLock|\.lock\(\)|\.read\(\)|\.write\(\))"
    ["serialization"]="(serde|Serialize|Deserialize|json|toml)"
    ["logging"]="(tracing|log::|debug!|info!|warn!|error!)"
    ["testing"]="(#\[test\]|#\[cfg\(test\)\]|mod tests)"
    ["unsafe"]="(unsafe |unsafe\{|unsafe_fn)"
    ["ffi"]="(extern |#\[no_mangle\]|libc::|std::ffi)"
)

# Predefined patterns for general code analysis
declare -A GENERAL_PATTERNS=(
    ["todo"]="(TODO|FIXME|XXX|HACK|BUG)"
    ["documentation"]="(///|//!|#\[doc)"
    ["feature-gates"]="(#\[cfg\()"
    ["public-api"]="(pub fn|pub struct|pub enum|pub trait|pub mod)"
    ["imports"]="(use |extern crate|mod )"
)

# Show usage information
show_usage() {
    cat << EOF
Usage: analyze-patterns [OPTIONS]

Analyze codebase for recurring patterns, similar implementations, and refactoring opportunities.

Options:
    --pattern=<name>     Pattern to search for (error-handling, async-patterns, singleton, etc.)
    --language=<lang>    Filter by language (rust, go, py, js, ts, etc.)
    --depth=<level>      Search depth: shallow (current dir) | medium (src/) | deep (entire repo)
    --output=<format>    Output format: text (default) | json | markdown
    --list-patterns      List all available predefined patterns
    --help               Show this help message

Examples:
    analyze-patterns --pattern=error-handling --language=rust
    analyze-patterns --pattern=async-patterns --depth=deep --output=json
    analyze-patterns --pattern=mutex-patterns --output=markdown
    analyze-patterns --list-patterns

Predefined Patterns (Rust):
    error-handling    - Result, Error types, thiserror, anyhow
    async-patterns    - async/await, tokio, futures
    singleton         - lazy_static, once_cell, Arc<Mutex>
    factory           - Factory pattern implementations
    builder           - Builder pattern implementations
    trait-patterns    - trait definitions and implementations
    mutex-patterns    - Mutex, RwLock usage patterns
    serialization     - serde, Serialize, Deserialize
    logging           - tracing, log macros
    testing           - Test modules and attributes
    unsafe            - unsafe code blocks
    ffi               - Foreign function interface patterns

General Patterns:
    todo              - TODO, FIXME, XXX comments
    documentation     - Documentation comments
    feature-gates     - Conditional compilation
    public-api        - Public function/struct definitions
    imports           - Import statements
EOF
}

# List all available patterns
list_patterns() {
    echo "Available Predefined Patterns"
    echo "============================"
    echo ""
    echo "Rust-Specific Patterns:"
    echo "----------------------"
    for pattern in "${!RUST_PATTERNS[@]}"; do
        printf "  %-20s %s\n" "$pattern" "${RUST_PATTERNS[$pattern]}"
    done
    echo ""
    echo "General Patterns:"
    echo "----------------"
    for pattern in "${!GENERAL_PATTERNS[@]}"; do
        printf "  %-20s %s\n" "$pattern" "${GENERAL_PATTERNS[$pattern]}"
    done
    echo ""
    echo "Custom Patterns:"
    echo "---------------"
    echo "  You can use any regex pattern with --pattern=<regex>"
    echo "  Example: --pattern='Arc<Mutex'"
}

# Parse command line arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --pattern=*)
                PATTERN="${1#*=}"
                shift
                ;;
            --language=*)
                LANGUAGE="${1#*=}"
                shift
                ;;
            --depth=*)
                DEPTH="${1#*=}"
                shift
                ;;
            --output=*)
                OUTPUT="${1#*=}"
                shift
                ;;
            --list-patterns)
                list_patterns
                exit 0
                ;;
            --help|-h)
                show_usage
                exit 0
                ;;
            *)
                echo "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
    done
}

# Get search directory based on depth
get_search_dir() {
    case $DEPTH in
        shallow)
            echo "."
            ;;
        medium)
            echo "core/src desktop/src app/src web/src"
            ;;
        deep)
            echo "."
            ;;
        *)
            echo "core/src desktop/src app/src web/src"
            ;;
    esac
}

# Get file extension filter based on language
get_file_filter() {
    case $LANGUAGE in
        rust|rs)
            echo "--include='*.rs'"
            ;;
        go|golang)
            echo "--include='*.go'"
            ;;
        python|py)
            echo "--include='*.py'"
            ;;
        javascript|js)
            echo "--include='*.js'"
            ;;
        typescript|ts)
            echo "--include='*.ts' --include='*.tsx'"
            ;;
        java)
            echo "--include='*.java'"
            ;;
        cpp|c++)
            echo "--include='*.cpp' --include='*.hpp' --include='*.h'"
            ;;
        *)
            if [[ "$LANGUAGE" == "rust" ]] || [[ -z "$LANGUAGE" ]]; then
                echo "--include='*.rs'"
            else
                echo ""
            fi
            ;;
    esac
}

# Get regex pattern for search
get_search_pattern() {
    local pattern_name="$1"
    
    # Check if it's a predefined Rust pattern
    if [[ -n "${RUST_PATTERNS[$pattern_name]}" ]]; then
        echo "${RUST_PATTERNS[$pattern_name]}"
        return
    fi
    
    # Check if it's a predefined general pattern
    if [[ -n "${GENERAL_PATTERNS[$pattern_name]}" ]]; then
        echo "${GENERAL_PATTERNS[$pattern_name]}"
        return
    fi
    
    # Otherwise, treat it as a custom regex
    echo "$pattern_name"
}

# Count occurrences of pattern
count_occurrences() {
    local pattern="$1"
    local search_dir="$2"
    local file_filter="$3"
    
    local count=0
    for dir in $search_dir; do
        if [[ -d "$PROJECT_ROOT/$dir" ]]; then
            if [[ -n "$file_filter" ]]; then
                # Use eval to handle multiple --include flags
                local dir_count=$(eval "grep -r -E '$pattern' $file_filter '$PROJECT_ROOT/$dir' 2>/dev/null | wc -l")
            else
                local dir_count=$(grep -r -E "$pattern" "$PROJECT_ROOT/$dir" 2>/dev/null | wc -l)
            fi
            count=$((count + dir_count))
        fi
    done
    
    echo "$count"
}

# Find files containing pattern
find_files_with_pattern() {
    local pattern="$1"
    local search_dir="$2"
    local file_filter="$3"
    
    local files=""
    for dir in $search_dir; do
        if [[ -d "$PROJECT_ROOT/$dir" ]]; then
            if [[ -n "$file_filter" ]]; then
                local dir_files=$(eval "grep -r -l -E '$pattern' $file_filter '$PROJECT_ROOT/$dir' 2>/dev/null")
            else
                local dir_files=$(grep -r -l -E "$pattern" "$PROJECT_ROOT/$dir" 2>/dev/null)
            fi
            if [[ -n "$dir_files" ]]; then
                files="$files $dir_files"
            fi
        fi
    done
    
    # Remove duplicates and sort
    echo "$files" | tr ' ' '\n' | sort -u | grep -v '^$'
}

# Get line matches with context
get_matches_with_context() {
    local pattern="$1"
    local search_dir="$2"
    local file_filter="$3"
    local context_lines="${4:-2}"
    
    for dir in $search_dir; do
        if [[ -d "$PROJECT_ROOT/$dir" ]]; then
            if [[ -n "$file_filter" ]]; then
                eval "grep -r -n -E -B $context_lines -A $context_lines '$pattern' $file_filter '$PROJECT_ROOT/$dir' 2>/dev/null" || true
            else
                grep -r -n -E -B "$context_lines" -A "$context_lines" "$pattern" "$PROJECT_ROOT/$dir" 2>/dev/null || true
            fi
        fi
    done
}

# Analyze pattern similarity
analyze_similarity() {
    local files="$1"
    local pattern="$2"
    
    # This is a simplified similarity analysis
    # In a real implementation, you might use more sophisticated algorithms
    local file_count=$(echo "$files" | wc -l)
    
    if [[ $file_count -eq 0 ]]; then
        echo "0"
        return
    fi
    
    # Calculate similarity based on pattern consistency
    # Higher count = more similar implementations
    if [[ $file_count -ge 10 ]]; then
        echo "high"
    elif [[ $file_count -ge 5 ]]; then
        echo "medium"
    else
        echo "low"
    fi
}

# Generate refactoring suggestions
generate_suggestions() {
    local pattern_name="$1"
    local file_count="$2"
    local occurrence_count="$3"
    
    local suggestions=""
    
    case $pattern_name in
        error-handling)
            if [[ $file_count -gt 5 ]]; then
                suggestions="$suggestions
- Consider creating a centralized error type to reduce duplication
- Evaluate using anyhow for application code vs thiserror for libraries"
            fi
            if [[ $occurrence_count -gt 50 ]]; then
                suggestions="$suggestions
- High error handling density - consider error recovery strategies
- Review error messages for consistency"
            fi
            ;;
        async-patterns)
            if [[ $file_count -gt 5 ]]; then
                suggestions="$suggestions
- Consider extracting common async patterns into utility functions
- Review for potential race conditions or deadlocks"
            fi
            ;;
        singleton)
            if [[ $file_count -gt 3 ]]; then
                suggestions="$suggestions
- Multiple singleton patterns detected - consider dependency injection
- Review thread safety of shared state"
            fi
            ;;
        mutex-patterns)
            if [[ $file_count -gt 5 ]]; then
                suggestions="$suggestions
- High mutex usage - review for potential contention points
- Consider lock-free data structures where appropriate"
            fi
            ;;
        unsafe)
            if [[ $occurrence_count -gt 0 ]]; then
                suggestions="$suggestions
- Review all unsafe blocks for soundness
- Document safety invariants for each unsafe usage"
            fi
            ;;
        todo)
            if [[ $occurrence_count -gt 0 ]]; then
                suggestions="$suggestions
- Address TODO items before release
- Convert FIXME items to tracked issues"
            fi
            ;;
        *)
            if [[ $file_count -gt 10 ]]; then
                suggestions="$suggestions
- Pattern found in many files - consider abstraction/extraction
- Review for consistency across implementations"
            fi
            ;;
    esac
    
    echo "$suggestions"
}

# Output results in text format
output_text() {
    local pattern_name="$1"
    local search_pattern="$2"
    local files="$3"
    local occurrence_count="$4"
    local similarity="$5"
    local suggestions="$6"
    
    echo ""
    echo "=========================================="
    echo "Pattern Analysis Report"
    echo "=========================================="
    echo ""
    echo "Pattern: $pattern_name"
    echo "Regex:   $search_pattern"
    echo ""
    echo "Summary"
    echo "-------"
    echo "Occurrences: $occurrence_count"
    echo "Files:       $(echo "$files" | wc -l)"
    echo "Similarity:  $similarity"
    echo ""
    
    if [[ -n "$files" ]]; then
        echo "Files Containing Pattern"
        echo "------------------------"
        echo "$files" | while read -r file; do
            if [[ -n "$file" ]]; then
                # Get relative path
                local rel_path="${file#$PROJECT_ROOT/}"
                # Count occurrences in this file
                local file_count=$(grep -c -E "$search_pattern" "$file" 2>/dev/null || echo "0")
                printf "  %-50s (%d occurrences)\n" "$rel_path" "$file_count"
            fi
        done
        echo ""
    fi
    
    if [[ -n "$suggestions" ]]; then
        echo "Refactoring Suggestions"
        echo "---------------------"
        echo "$suggestions"
        echo ""
    fi
    
    echo "=========================================="
}

# Output results in JSON format
output_json() {
    local pattern_name="$1"
    local search_pattern="$2"
    local files="$3"
    local occurrence_count="$4"
    local similarity="$5"
    local suggestions="$6"
    
    local file_array=""
    local first=true
    while IFS= read -r file; do
        if [[ -n "$file" ]]; then
            local rel_path="${file#$PROJECT_ROOT/}"
            local file_count=$(grep -c -E "$search_pattern" "$file" 2>/dev/null || echo "0")
            if [[ "$first" == "true" ]]; then
                first=false
            else
                file_array="$file_array,"
            fi
            file_array="$file_array{\"file\":\"$rel_path\",\"occurrences\":$file_count}"
        fi
    done <<< "$files"
    
    # Escape suggestions for JSON
    local json_suggestions=$(echo "$suggestions" | sed 's/"/\\"/g' | tr '\n' ' ')
    
    cat << EOF
{
  "pattern": "$pattern_name",
  "regex": "$search_pattern",
  "occurrences": $occurrence_count,
  "file_count": $(echo "$files" | wc -l),
  "similarity": "$similarity",
  "files": [$file_array],
  "suggestions": "$json_suggestions"
}
EOF
}

# Output results in markdown format
output_markdown() {
    local pattern_name="$1"
    local search_pattern="$2"
    local files="$3"
    local occurrence_count="$4"
    local similarity="$5"
    local suggestions="$6"
    
    cat << EOF
# Pattern Analysis: $pattern_name

**Regex Pattern:** \`$search_pattern\`

## Summary

| Metric | Value |
|--------|-------|
| Occurrences | $occurrence_count |
| Files | $(echo "$files" | wc -l) |
| Similarity | $similarity |

## Files

EOF
    
    if [[ -n "$files" ]]; then
        echo "| File | Occurrences |"
        echo "|------|-------------|"
        echo "$files" | while read -r file; do
            if [[ -n "$file" ]]; then
                local rel_path="${file#$PROJECT_ROOT/}"
                local file_count=$(grep -c -E "$search_pattern" "$file" 2>/dev/null || echo "0")
                echo "| \`$rel_path\` | $file_count |"
            fi
        done
        echo ""
    fi
    
    if [[ -n "$suggestions" ]]; then
        echo "## Refactoring Suggestions"
        echo ""
        echo "$suggestions" | while read -r line; do
            if [[ -n "$line" ]]; then
                echo "$line"
            fi
        done
        echo ""
    fi
    
    echo "---"
    echo "*Generated by analyze-patterns*"
}

# Main analysis function
run_analysis() {
    if [[ -z "$PATTERN" ]]; then
        echo "Error: No pattern specified"
        show_usage
        exit 1
    fi
    
    # Get search parameters
    local search_pattern=$(get_search_pattern "$PATTERN")
    local search_dir=$(get_search_dir)
    local file_filter=$(get_file_filter)
    
    # Run analysis
    local occurrence_count=$(count_occurrences "$search_pattern" "$search_dir" "$file_filter")
    local files=$(find_files_with_pattern "$search_pattern" "$search_dir" "$file_filter")
    local similarity=$(analyze_similarity "$files" "$search_pattern")
    local suggestions=$(generate_suggestions "$PATTERN" "$(echo "$files" | wc -l)" "$occurrence_count")
    
    # Output results
    case $OUTPUT in
        json)
            output_json "$PATTERN" "$search_pattern" "$files" "$occurrence_count" "$similarity" "$suggestions"
            ;;
        markdown|md)
            output_markdown "$PATTERN" "$search_pattern" "$files" "$occurrence_count" "$similarity" "$suggestions"
            ;;
        text|*)
            output_text "$PATTERN" "$search_pattern" "$files" "$occurrence_count" "$similarity" "$suggestions"
            ;;
    esac
}

# Main entry point
main() {
    parse_args "$@"
    
    # Check if we're in a project directory
    if [[ ! -d "$PROJECT_ROOT/core" ]] && [[ ! -f "$PROJECT_ROOT/Cargo.toml" ]]; then
        echo "Warning: Project structure not detected at $PROJECT_ROOT"
        echo "Searching in current directory instead..."
        PROJECT_ROOT="$(pwd)"
    fi
    
    run_analysis
}

# Run main function
main "$@"
